{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"style": {
				"useConst": "error",
				"useTemplate": "error",
				"useExportType": "error",
				"useImportType": "error",
				"useNodejsImportProtocol": "error",
				"noNonNullAssertion": "warn",
				"noParameterAssign": "error",
				"useDefaultParameterLast": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noConsole": "warn",
				"noDoubleEquals": "error",
				"noAssignInExpressions": "error",
				"noImplicitAnyLet": "error"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": { "maxAllowedComplexity": 25 }
				},
				"noExcessiveLinesPerFunction": {
					"level": "warn",
					"options": { "maxLines": 500 }
				},
				"noForEach": "warn",
				"noBannedTypes": "error",
				"useFlatMap": "error"
			},
			"performance": {
				"noDelete": "warn"
			},
			"security": {
				"noGlobalEval": "error"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "off"
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/*.md",
			"!**/node_modules",
			"!**/dist",
			"!**/web-dist",
			"!coverage",
			"!utils/coverage",
			"!pi-session-*.html",
			"!picky-handoff"
		]
	},
	"overrides": [
		{
			"includes": ["interactive-shell/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noControlCharactersInRegex": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts", "**/*.spec.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
