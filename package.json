{
	"name": "@jonghakseo/my-pi",
	"version": "0.1.1",
	"description": "A personal AI operating system built on pi — 9 agents, local/npm extensions, 8 themes",
	"keywords": [
		"pi-package"
	],
	"files": [
		"agents/",
		"extensions/.env.example",
		"extensions/.gitignore",
		"extensions/AGENTS.md",
		"extensions/archive-to-html/",
		"extensions/bash-tool-override/",
		"extensions/biome.json",
