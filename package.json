{
	"name": "@jonghakseo/my-pi",
	"version": "0.1.1",
	"description": "A personal AI operating system built on pi — 9 agents, local/npm extensions, 8 themes",
	"keywords": [
		"pi-package"
	],
	"files": [
		"agents/",
		"extensions/",
		"!extensions/**/.env",
		"!extensions/.pi-lens/",
		"!extensions/coverage/",
		"!extensions/picky-handoff/",
		"!extensions/prompt-suggest-lite/.data/",
		"!extensions/usage-reporter/",
		"!extensions/utils/coverage/",
		"skills/",
		"themes/",
		"scripts/sync-agents.mjs",
		"docs/assets/",
		"custom-style.json",
		"prompt-suggest-lite.json",
		"INSTALL.md",
		"README.ko.md",
		"SYSTEM.md"
	],
	"license": "MIT",
	"author": "Jonghakseo",
	"repository": {
		"type": "git",
		"url": "https://github.com/Jonghakseo/my-pi.git"
	},
	"scripts": {
		"sync-agents": "node scripts/sync-agents.mjs",
		"postinstall": "node scripts/sync-agents.mjs"
	},
	"pi": {
		"extensions": [
			"./extensions"
		],
		"skills": [
			"./skills"
		],
		"themes": [
			"./themes"
		]
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
