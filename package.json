		"extensions/footer/",
		"extensions/fork-panel/",
		"extensions/github-pr-merge/",
		"extensions/interactive-shell/",
		"extensions/notify/",
		"extensions/package.json",
		"extensions/pnpm-lock.yaml",
		"extensions/pnpm-workspace.yaml",
		"extensions/pr-comments/",
		"extensions/pr-review-re-request/",
		"extensions/prompt-suggest-lite/",
		"extensions/read-tool-override/",
		"extensions/README.md",
		"extensions/theme-cycler/",
		"extensions/to-html/",
		"extensions/tool-group-renderer/",
		"extensions/tooling/",
		"extensions/tsconfig.json",
		"extensions/tsconfig.web-access.json",
		"extensions/until/",
