		"skills/design-first/",
		"skills/dynamic-workflow/",
		"skills/interactive-shell/",
		"skills/memory-manage/",
		"skills/pi-auto-update/",
		"skills/self-healing/",
		"skills/ship/",
		"skills/skill-creator/",
		"skills/stress-interview/",
		"skills/systematic-debugging/",
		"skills/usage-analytics/",
		"themes/",
		"scripts/sync-agents.mjs",
		"scripts/validate-packlist.mjs",
		"docs/assets/",
		"custom-style.json",
		"prompt-suggest-lite.json",
		"INSTALL.md",
		"README.ko.md",
		"SYSTEM.md"
	],
	"license": "MIT",
	"author": "Jonghakseo",
	"repository": {
		"type": "git",
		"url": "https://github.com/Jonghakseo/my-pi.git"
	},
	"scripts": {
		"sync-agents": "node scripts/sync-agents.mjs",
		"validate:packlist": "node scripts/validate-packlist.mjs",
		"prepublishOnly": "pnpm run validate:packlist",
		"postinstall": "node scripts/sync-agents.mjs"
	},
	"pi": {
		"extensions": [
			"./extensions"
		],
		"skills": [
			"./skills"
		],
		"themes": [
			"./themes"
		]
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
